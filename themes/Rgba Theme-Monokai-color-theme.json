{
	"name": "Rgba Theme - Monokai",
	"colors": {
		"editor.background": "#272822",
		"editor.foreground": "#f8f8f2",
		"editor.selectionBackground": "#49483e",
		"editor.lineHighlightBackground": "#3e3d3250",
		"editorCursor.foreground": "#f8f8f0",
		"editorLineNumber.foreground": "#75715e",
		"editorLineNumber.activeForeground": "#f8f8f2",
		"editorGutter.background": "#272822",
		"editor.findMatchBackground": "#e6db7480",
		"editor.findMatchHighlightBackground": "#ffffff30",
		"editor.wordHighlightBackground": "#66d9ef30",
		"tab.activeBackground": "#272822",
		"tab.activeForeground": "#f8f8f2",
		"tab.inactiveBackground": "#1e1f1c",
		"tab.inactiveForeground": "#75715e",
		"tab.border": "#1e1f1c",
		"sideBar.background": "#1e1f1c",
		"sideBar.foreground": "#f8f8f2",
		"sideBar.border": "#1e1f1c",
		"sideBarTitle.foreground": "#75715e",
		"activityBar.background": "#1e1f1c",
		"activityBar.foreground": "#f8f8f2",
		"activityBar.border": "#1e1f1c",
		"activityBarBadge.background": "#a6e22e",
		"statusBar.background": "#1e1f1c",
		"statusBar.foreground": "#f8f8f2",
		"titleBar.activeBackground": "#1e1f1c",
		"panel.background": "#272822",
		"panel.border": "#49483e",
		"terminal.background": "#272822",
		"terminal.foreground": "#f8f8f2",
		"input.background": "#49483e",
		"input.foreground": "#f8f8f2",
		"input.border": "#75715e",
		"button.background": "#75715e",
		"button.foreground": "#f8f8f2"
	},
	"tokenColors": [
		{"name": "Comment", "scope": ["comment", "punctuation.definition.comment"], "settings": {"fontStyle": "italic", "foreground": "#75715e"}},
		{"name": "Variables", "scope": ["variable", "string constant.other.placeholder"], "settings": {"foreground": "#f8f8f2"}},
		{"name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": {"foreground": "#f92672"}},
		{"name": "Keyword, Storage", "scope": ["keyword", "storage.type", "storage.modifier"], "settings": {"foreground": "#f92672"}},
		{"name": "Operator", "scope": ["keyword.control", "punctuation"], "settings": {"foreground": "#f92672"}},
		{"name": "Tag", "scope": ["entity.name.tag"], "settings": {"foreground": "#f92672"}},
		{"name": "Function", "scope": ["entity.name.function", "meta.function-call", "variable.function", "support.function"], "settings": {"foreground": "#a6e22e"}},
		{"name": "Number, Constant", "scope": ["constant.numeric", "constant.language", "support.constant"], "settings": {"foreground": "#ae81ff"}},
		{"name": "String", "scope": ["string", "constant.other.symbol"], "settings": {"foreground": "#e6db74"}},
		{"name": "Class, Support", "scope": ["entity.name", "support.type", "support.class"], "settings": {"foreground": "#66d9ef"}},
		{"name": "Attributes", "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#a6e22e"}}
	]
}
