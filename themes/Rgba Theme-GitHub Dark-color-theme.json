{
	"name": "Rgba Theme - GitHub Dark",
	"colors": {
		"editor.background": "#0d1117",
		"editor.foreground": "#c9d1d9",
		"editor.selectionBackground": "#264f78",
		"editor.lineHighlightBackground": "#161b2250",
		"editorCursor.foreground": "#c9d1d9",
		"editorLineNumber.foreground": "#484f58",
		"editorLineNumber.activeForeground": "#c9d1d9",
		"editorGutter.background": "#0d1117",
		"editor.findMatchBackground": "#f2cc6080",
		"editor.findMatchHighlightBackground": "#ffffff20",
		"editor.wordHighlightBackground": "#58a6ff30",
		"tab.activeBackground": "#0d1117",
		"tab.activeForeground": "#c9d1d9",
		"tab.inactiveBackground": "#010409",
		"tab.inactiveForeground": "#484f58",
		"tab.border": "#30363d",
		"sideBar.background": "#010409",
		"sideBar.foreground": "#c9d1d9",
		"sideBar.border": "#30363d",
		"sideBarTitle.foreground": "#8b949e",
		"activityBar.background": "#010409",
		"activityBar.foreground": "#c9d1d9",
		"activityBar.border": "#30363d",
		"activityBarBadge.background": "#1f6feb",
		"statusBar.background": "#161b22",
		"statusBar.foreground": "#8b949e",
		"titleBar.activeBackground": "#161b22",
		"panel.background": "#0d1117",
		"panel.border": "#30363d",
		"terminal.background": "#0d1117",
		"terminal.foreground": "#c9d1d9",
		"input.background": "#161b22",
		"input.foreground": "#c9d1d9",
		"input.border": "#30363d",
		"button.background": "#1f6feb",
		"button.foreground": "#ffffff"
	},
	"tokenColors": [
		{"name": "Comment", "scope": ["comment", "punctuation.definition.comment"], "settings": {"fontStyle": "italic", "foreground": "#8b949e"}},
		{"name": "Variables", "scope": ["variable", "string constant.other.placeholder"], "settings": {"foreground": "#c9d1d9"}},
		{"name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": {"foreground": "#f85149"}},
		{"name": "Keyword, Storage", "scope": ["keyword", "storage.type", "storage.modifier"], "settings": {"foreground": "#ff7b72"}},
		{"name": "Operator", "scope": ["keyword.control", "punctuation"], "settings": {"foreground": "#ff7b72"}},
		{"name": "Tag", "scope": ["entity.name.tag"], "settings": {"foreground": "#7ee787"}},
		{"name": "Function", "scope": ["entity.name.function", "meta.function-call", "variable.function", "support.function"], "settings": {"foreground": "#d2a8ff"}},
		{"name": "Number, Constant", "scope": ["constant.numeric", "constant.language", "support.constant"], "settings": {"foreground": "#79c0ff"}},
		{"name": "String", "scope": ["string", "constant.other.symbol"], "settings": {"foreground": "#a5d6ff"}},
		{"name": "Class, Support", "scope": ["entity.name", "support.type", "support.class"], "settings": {"foreground": "#ffa657"}},
		{"name": "Attributes", "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#79c0ff"}}
	]
}
