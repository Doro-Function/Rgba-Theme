{
	"name": "Rgba Theme - Dracula",
	"colors": {
		"editor.background": "#282a36",
		"editor.foreground": "#f8f8f2",
		"editor.selectionBackground": "#44475a",
		"editor.lineHighlightBackground": "#44475a50",
		"editorCursor.foreground": "#f8f8f2",
		"editorLineNumber.foreground": "#6272a4",
		"editorLineNumber.activeForeground": "#f8f8f2",
		"editorGutter.background": "#282a36",
		"editor.findMatchBackground": "#ffb86c80",
		"editor.findMatchHighlightBackground": "#ffffff40",
		"editor.wordHighlightBackground": "#8be9fd30",
		"tab.activeBackground": "#282a36",
		"tab.activeForeground": "#f8f8f2",
		"tab.inactiveBackground": "#21222c",
		"tab.inactiveForeground": "#6272a4",
		"tab.border": "#191a21",
		"sideBar.background": "#21222c",
		"sideBar.foreground": "#f8f8f2",
		"sideBar.border": "#191a21",
		"sideBarTitle.foreground": "#6272a4",
		"activityBar.background": "#21222c",
		"activityBar.foreground": "#f8f8f2",
		"activityBar.border": "#191a21",
		"activityBarBadge.background": "#ff79c6",
		"statusBar.background": "#191a21",
		"statusBar.foreground": "#f8f8f2",
		"titleBar.activeBackground": "#21222c",
		"panel.background": "#282a36",
		"panel.border": "#44475a",
		"terminal.background": "#282a36",
		"terminal.foreground": "#f8f8f2",
		"input.background": "#44475a",
		"input.foreground": "#f8f8f2",
		"input.border": "#6272a4",
		"button.background": "#6272a4",
		"button.foreground": "#f8f8f2"
	},
	"tokenColors": [
		{"name": "Comment", "scope": ["comment", "punctuation.definition.comment"], "settings": {"fontStyle": "italic", "foreground": "#6272a4"}},
		{"name": "Variables", "scope": ["variable", "string constant.other.placeholder"], "settings": {"foreground": "#f8f8f2"}},
		{"name": "Colors", "scope": ["constant.other.color"], "settings": {"foreground": "#ffffff"}},
		{"name": "Invalid", "scope": ["invalid", "invalid.illegal"], "settings": {"foreground": "#ff5555"}},
		{"name": "Keyword, Storage", "scope": ["keyword", "storage.type", "storage.modifier"], "settings": {"foreground": "#ff79c6"}},
		{"name": "Operator, Misc", "scope": ["keyword.control", "punctuation", "meta.tag"], "settings": {"foreground": "#ff79c6"}},
		{"name": "Tag", "scope": ["entity.name.tag"], "settings": {"foreground": "#ff79c6"}},
		{"name": "Function", "scope": ["entity.name.function", "meta.function-call", "variable.function", "support.function"], "settings": {"foreground": "#50fa7b"}},
		{"name": "Number, Constant", "scope": ["constant.numeric", "constant.language", "support.constant", "constant.character"], "settings": {"foreground": "#bd93f9"}},
		{"name": "String", "scope": ["string", "constant.other.symbol", "entity.other.inherited-class"], "settings": {"foreground": "#f1fa8c"}},
		{"name": "Class, Support", "scope": ["entity.name", "support.type", "support.class"], "settings": {"foreground": "#8be9fd"}},
		{"name": "Attributes", "scope": ["entity.other.attribute-name"], "settings": {"foreground": "#50fa7b"}}
	]
}
