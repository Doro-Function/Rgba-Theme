{
  "name": "rgba-theme",
  "displayName": "Rgba Theme",
  "description": "A VSCode theme with RGBA color customization support | 支持 RGBA 自定义颜色的 VSCode 主题",
  "version": "0.1.0",
  "publisher": "ChenJiaLin-Mr",
  "author": "ChenJiaLin-Mr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChenJiaLin-Mr/Rgba-Theme"
  },
  "bugs": {
    "url": "https://github.com/ChenJiaLin-Mr/Rgba-Theme/issues"
  },
  "homepage": "https://github.com/ChenJiaLin-Mr/Rgba-Theme#readme",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#263238",
    "theme": "dark"
  },
  "keywords": [
    "theme",
    "rgba",
    "color",
    "customizable",
    "dark"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onCommand:rgba-theme.customize",
    "onCommand:rgba-theme.reset"
  ],
  "main": "./extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Rgba Theme",
        "uiTheme": "vs-dark",
        "path": "./themes/Rgba Theme-color-theme.json"
      },
      {
        "label": "Rgba Theme - Dracula",
        "uiTheme": "vs-dark",
        "path": "./themes/Rgba Theme-Dracula-color-theme.json"
      },
      {
        "label": "Rgba Theme - Monokai",
        "uiTheme": "vs-dark",
        "path": "./themes/Rgba Theme-Monokai-color-theme.json"
      },
      {
        "label": "Rgba Theme - GitHub Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/Rgba Theme-GitHub Dark-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "rgba-theme.customize",
        "title": "Customize Colors",
        "category": "Rgba Theme"
      },
      {
        "command": "rgba-theme.reset",
        "title": "Reset to Default",
        "category": "Rgba Theme"
      }
    ],
    "menus": {
      "extension/context": [
        {
          "command": "rgba-theme.customize",
          "when": "extensionStatus == installed"
        }
      ]
    }
  }
}
